        "local_service_homepage"
      ],
      "content_entity_ref": "hero",
      "template": {
        "path": "index.html#hero",
        "render_engine": "html",
        "partial_name": "hero"
      },
      "acf": {
        "group_key": "group_hero",
        "group_name": "Hero"
      },
      "variants": [
        "full-bleed-background"
      ],
      "themes": [
        "brand-primary"
      ],
      "constraints": {
        "max_instances_per_page": 1,
        "requires_fields": [
          "headline",
          "supporting_text",
          "primary_cta",
          "background_image"
        ]
      },
      "performance": {
        "weight": "high",
        "heavy_media": true,
        "interactive": false
      }
    },
