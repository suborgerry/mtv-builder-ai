{
  "page_id": "ricks-ac-homepage",
  "entities": {
    "hero": {
      "entity_type": "section",
      "purpose": "Present the core value proposition, full-width hero image, and top conversion path.",
      "fields": {
        "eyebrow": {
          "type": "text",
          "required": true,
          "editable": true,
          "default": "Fast, Honest, and Dependable"
        },
        "headline": {
          "type": "text",
          "required": true,
          "editable": true,
          "default": "HVAC service built for real homes, real businesses, and real urgency."
        },
        "supporting_text": {
          "type": "rich_text",
          "required": true,
          "editable": true,
          "default": "Rick's AC Maintenance & Service LLC handles repair, installation, maintenance, and indoor air quality across Hancock County, Mississippi and Louisiana communities with a practical, no-nonsense service approach."
        },
        "primary_cta": {
          "type": "link",
          "required": true,
          "editable": true,
          "default": {
            "label": "Schedule Service Today",
            "href": "#contact"
          }
        },
        "secondary_cta": {
          "type": "link",
          "required": false,
          "editable": true,
          "default": {
            "label": "Explore Services",
            "href": "#services"
          }
        },
        "background_image": {
          "type": "image",
          "required": true,
          "editable": true,
          "default": {
            "src": "assets/images/Home-hero-background.jpg",
            "alt": "HVAC outdoor unit near home exterior"
          }
        },
        "brand_logo": {
          "type": "image",
          "required": true,
          "editable": true,
          "default": {
            "src": "assets/images/Ricks-logo-white.png",
            "alt": "Rick's AC Maintenance and Service LLC white logo"
          }
        },
        "metrics": {
          "type": "repeater",
          "required": true,
          "editable": true,
          "default": [
            {
              "title": "18 Years",
              "description": "Trusted HVAC experience"
            },
            {
              "title": "Licensed",
              "description": "Louisiana and Mississippi credentials"
            },
            {
              "title": "All Major Brands",
              "description": "Service, replacement, and maintenance"
            }
          ]
        }
      }
    },
