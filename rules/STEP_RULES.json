{
  "reference_root": "boilerplate/json_references",
  "prompt_root": "boilerplate/prompts",
  "build_targets": {
    "html": [
      "index.html",
      "package.json",
      "vite.config.js",
      "postcss.config.js",
      "tailwind.config.js",
      "src/input.css",
      "partials/*.html"
    ],
    "wordpress": [
      "production/wp_theme/partials/*.php",
      "production/wp_theme/functions.php",
      "production/wp_theme/acf-json/*.json",
      "production/wp_theme/mc_template.php",
      "production/wp_theme/style.css"
    ]
  },
  "logical_phases": [
    {
      "phase": 1,
      "name": "Strategy",
      "steps": [
        1,
        2
      ],
      "canonical_outputs": [
        "01_page_goal.json",
        "02_content_model.json",
        "03_page_structure.json",
        "05_strategy.json"
      ],
      "static_inputs": [
        "04_section_registry.json"
      ]
    },
    {
      "phase": 2,
      "name": "Render",
      "steps": [
        3
      ],
      "canonical_outputs": [
        "06_render.json"
      ]
    },
    {
      "phase": 3,
      "name": "Delivery",
      "steps": [
        4
      ],
      "canonical_outputs": [
        "07_delivery.json"
      ]
    },
    {
      "phase": 4,
      "name": "Quality",
      "steps": [
        5,
        6
      ],
      "canonical_outputs": [
        "08_quality.json",
        "09_build.json"
      ]
    },
    {
      "phase": 5,
      "name": "Build Targets",
      "steps": [
        7,
        8
      ],
      "required_inputs": [
        "05_strategy.json",
        "06_render.json",
        "07_delivery.json",
        "08_quality.json",
        "09_build.json"
      ]
    }
  ],
  "steps": [
    {
      "step": 1,
      "name": "Intent + Structure",
      "logical_phase": "Strategy",
      "prompt": "boilerplate/prompts/01_strategy_bundle.md",
      "reads": [
        "04_section_registry.json"
      ],
      "writes": [
        "01_page_goal.json",
        "02_content_model.json",
        "03_page_structure.json",
        "05_strategy.json"
      ],
      "must_not_modify": [
        "06_render.json",
        "07_delivery.json",
        "08_quality.json",
        "09_build.json"
      ]
    },
    {
      "step": 2,
      "name": "Layout + UI",
      "logical_phase": "Strategy",
      "prompt": "boilerplate/prompts/01_strategy_bundle.md",
      "reads": [
        "01_page_goal.json",
        "02_content_model.json",
        "03_page_structure.json",
        "04_section_registry.json",
        "05_strategy.json"
      ],
      "writes": [
        "05_strategy.json"
      ],
      "must_not_modify": [
        "06_render.json",
        "07_delivery.json",
        "08_quality.json",
        "09_build.json"
      ]
    },
    {
      "step": 3,
      "name": "Render + Schema",
      "logical_phase": "Render",
      "prompt": "boilerplate/prompts/02_render_bundle.md",
      "reads": [
        "01_page_goal.json",
        "02_content_model.json",
        "05_strategy.json"
      ],
      "writes": [
        "06_render.json"
      ],
      "must_not_modify": [
        "07_delivery.json",
        "08_quality.json",
        "09_build.json"
      ]
    },
    {
      "step": 4,
      "name": "Performance + Images",
      "logical_phase": "Delivery",
      "prompt": "boilerplate/prompts/03_delivery_bundle.md",
      "reads": [
        "03_page_structure.json",
        "05_strategy.json",
        "06_render.json"
      ],
      "writes": [
        "07_delivery.json"
      ],
      "must_not_modify": [
        "08_quality.json",
        "09_build.json"
      ]
    },
    {
      "step": 5,
      "name": "Content Optimization",
      "logical_phase": "Quality",
      "prompt": "boilerplate/prompts/04_quality_bundle.md",
      "reads": [
        "01_page_goal.json",
        "02_content_model.json",
        "03_page_structure.json",
        "05_strategy.json",
        "06_render.json",
        "07_delivery.json"
      ],
      "writes": [
        "08_quality.json"
      ],
      "must_not_modify": [
        "09_build.json"
      ]
    },
    {
      "step": 6,
      "name": "QA + Build Config",
      "logical_phase": "Quality",
      "prompt": "boilerplate/prompts/04_quality_bundle.md",
      "reads": [
        "05_strategy.json",
        "06_render.json",
        "07_delivery.json",
        "08_quality.json"
      ],
      "writes": [
        "08_quality.json",
        "09_build.json"
      ],
      "must_not_modify": []
    },
    {
      "step": 7,
      "name": "HTML + Tailwind + Vite Build",
      "logical_phase": "Build Targets",
      "prompt": "boilerplate/prompts/05_build_targets.md",
      "reads": [
        "05_strategy.json",
        "06_render.json",
        "07_delivery.json",
        "08_quality.json",
        "09_build.json"
      ],
      "writes": [
        "index.html",
        "package.json",
        "vite.config.js",
        "postcss.config.js",
        "tailwind.config.js",
        "src/input.css",
        "partials/*.html"
      ],
      "must_not_modify": [
        "01_page_goal.json",
        "02_content_model.json",
        "03_page_structure.json",
        "04_section_registry.json"
      ]
    },
    {
      "step": 8,
      "name": "WordPress Build",
      "logical_phase": "Build Targets",
      "prompt": "boilerplate/prompts/05_build_targets.md",
      "reads": [
        "05_strategy.json",
        "06_render.json",
        "07_delivery.json",
        "08_quality.json",
        "09_build.json"
      ],
      "writes": [
        "production/wp_theme/partials/*.php",
        "production/wp_theme/functions.php",
        "production/wp_theme/acf-json/*.json",
        "production/wp_theme/mc_template.php",
        "production/wp_theme/style.css"
      ],
      "must_not_modify": [
        "01_page_goal.json",
        "02_content_model.json",
        "03_page_structure.json",
        "04_section_registry.json"
      ]
    }
  ]
}
